{
    "include": ["**/*.js", "**/*.ts", "**/*.tsx"],
    "exclude": [ "build/*", "bfh3-browser-implant/*" ],
    "compilerOptions": {
        "outDir": "./build/",
        "sourceMap": true,
        "noImplicitAny": true,
        "module": "es6",
        "target": "es2015",
        "jsx": "react",
        "allowJs": true, // should be enabled for `*.config.js` files
        "strict": true,
        "moduleResolution": "node"
    }
}
