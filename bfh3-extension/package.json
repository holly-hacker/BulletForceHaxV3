        "@wasm-tool/wasm-pack-plugin": "^1.7.0",
        "copy-webpack-plugin": "^12.0.2",
        "ts-loader": "^9.5.2",
        "typescript": "^5.7.3",
        "webpack": "^5.98.0",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "base64-js": "^1.5.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    }
