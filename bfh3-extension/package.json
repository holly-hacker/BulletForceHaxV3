{
    "name": "bfh3-extension",
    "version": "0.1.0",
    "description": "BulletForceHaxV3 Browser Extension",
    "private": true,
    "type": "module",
    "scripts": {
        "watch": "webpack --mode=development --watch --config webpack.config.js",
        "build-dev": "webpack --mode=development --config webpack.config.js",
        "build": "webpack --mode=production --config webpack.config.js",
        "format": "prettier --write --ignore-unknown \"{config,public,src}/**/*.{html,css,js,ts,json}\""
    },
    "devDependencies": {
        "@eslint/js": "^9.21.0",
        "@types/chrome": "^0.0.306",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@wasm-tool/wasm-pack-plugin": "^1.7.0",
        "copy-webpack-plugin": "^12.0.2",
        "eslint": "^9.21.0",
        "eslint-plugin-react": "^7.37.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^16.0.0",
        "ts-loader": "^9.5.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.25.0",
        "webpack": "^5.98.0",
        "webpack-cli": "^6.0.1"
    },
    "dependencies": {
        "@msgpack/msgpack": "^3.1.0",
        "@tanstack/react-table": "^8.21.2",
        "@tanstack/react-virtual": "^3.13.2",
        "base64-js": "^1.5.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    }
