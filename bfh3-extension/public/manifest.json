{
    "$schema": "https://raw.githubusercontent.com/cezaraugusto/chrome-extension-manifest-json-schema/refs/heads/main/manifest/manifest.schema.v3.json",
    "manifest_version": 3,
    "name": "BulletForceHaxV3",
    "short_name": "BFHv3",
    "version": "0.1.0",
    "description": "BulletForceHaxV3 Browser Extension",
    "devtools_page": "devtools_main.html",
    "icons": {
        "16": "icons/icon_16.png",
        "32": "icons/icon_32.png",
        "48": "icons/icon_48.png",
        "128": "icons/icon_128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Open BulletForceHaxV3 panel",
        "default_state": "disabled"
    },
    "permissions": ["storage", "unlimitedStorage", "tabs", "sidePanel"],
    "host_permissions": ["*://*.crazygames.com/*"],
    "externally_connectable": {
        "matches": [
            "*://www.crazygames.com/game/bullet-force-multiplayer*",
            "*://games.crazygames.com/en_US/bullet-force-multiplayer/index.html*",
            "*://bullet-force-multiplayer.game-files.crazygames.com/unity/unity2020/bullet-force-multiplayer.html*"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "*://bullet-force-multiplayer.game-files.crazygames.com/unity/unity2020/bullet-force-multiplayer.html*"
            ],
            "all_frames": true,
            "run_at": "document_start",
            "js": ["contentScripts_gameFrame_documentStart.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "webAccessibleResources_gameFrameRuntime.js",
                "wasm/index.js",
                "wasm/index_bg.wasm",
                "init_wasm_module.js"
            ],
            "matches": [
                "*://bullet-force-multiplayer.game-files.crazygames.com/*"
            ],
            "use_dynamic_url": true
        }
    ]
}
